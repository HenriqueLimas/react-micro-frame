{
  "name": "react-micro-frame",
  "version": "0.0.0",
  "description": "Stream independently rendered HTML into React applications on the server and in the browser.",
  "type": "module",
  "sideEffects": false,
  "workspaces": [
    "playground/react-client",
    "playground/react-server",
    "playground/marko-server"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit && npm run check --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "playground": "npm run build && npm run playground:dev",
    "playground:dev": "concurrently -k -n marko,react,host -c magenta,blue,green \"npm run dev -w playground-marko-server\" \"npm run dev -w playground-react-server\" \"npm run dev -w playground-react-client\"",
    "test:e2e": "npm run build && playwright test --config playground/playwright.config.ts"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "writable-dom": "^1.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/jsdom": "^21.1.7",
    "concurrently": "^10.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
