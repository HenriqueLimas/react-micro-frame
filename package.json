{
  "name": "@micro-frame/react",
  "version": "0.0.1",
  "description": "Stream independently rendered HTML into React applications on the server and in the browser.",
  "type": "module",
  "sideEffects": false,
  "workspaces": [
    ".",
    "playground/react-client",
    "playground/react-server",
    "playground/marko-server"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "changeset": "changeset",
    "check": "tsc --noEmit && npm run check --workspace playground-react-client --workspace playground-react-server --workspace playground-marko-server --if-present",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "playground": "npm run build && npm run playground:dev",
    "playground:dev": "concurrently -k -n marko,react,host -c magenta,blue,green \"npm run dev -w playground-marko-server\" \"npm run dev -w playground-react-server\" \"npm run dev -w playground-react-client\"",
    "test:e2e": "npm run build && playwright test --config playground/playwright.config.ts",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "writable-dom": "^1.0.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@playwright/test": "^1.55.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "jsdom": "^26.1.0",
    "prettier": "^3.9.5",
    "prettier-plugin-marko": "^4.0.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
